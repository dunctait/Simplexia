{
  "scripts": {
    "build:globe": "esbuild src/globe-scene.js --bundle --format=iife --global-name=IslandGlobeBundle --outfile=vendor/globe-bundle.js",
    "test": "node --test tests/*.test.js",
    "e2e": "node scripts/playwright-smoke.js && node scripts/playwright-layout-check.js",
    "predeploy": "powershell -ExecutionPolicy Bypass -File scripts/predeploy-check.ps1",
    "check": "npm test && npm run e2e"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "playwright": "^1.58.2"
  },
  "dependencies": {
    "three": "^0.184.0"
  }
}
